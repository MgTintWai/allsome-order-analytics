APP_NAME="Order Analytics API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4
#
# --- php.ini (uploads; set on the real PHP used by php-fpm / Apache / CLI) ---
# Laravel enforces 4 MB on the "csv" field (max:4096 KiB). PHP must allow a *larger*
# wire size so the request reaches Laravel first; then validation returns 422.
# Suggested ceiling (example 20 MB; pick what fits your infra):
#   post_max_size=20M
#   upload_max_filesize=20M
#   memory_limit=128M
# Never show errors in the HTTP body in production:
#   display_errors=Off
#   log_errors=On
#

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Optional. This API is CSV-only; no MySQL is required. Leave as-is or point to any DB
# only if you add features that use Eloquent later.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=order_analytics
DB_USERNAME=root
DB_PASSWORD=

# Use the filesystem, not the database, so the app works with zero DB setup.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# `database` would require the `cache` table; `file` is enough (also used by `throttle` on API routes).
CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
